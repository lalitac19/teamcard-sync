{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": false,
    "allowJs": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": false,
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": [
      "node",
      "vite/client"
    ],
    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ],
    "paths": {
      "@assets/*": [
        "./src/assets/*"
      ],
      "@store/*": [
        "./src/store/*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@customtypes/*": [
        "./src/types/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@src/*": [
        "./src/*"
      ],
      "@hooks/*": [
        "./src/hooks/*"
      ],
      "@routes/*": [
        "./src/routes/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@domains/*": [
        "./src/domains/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "vite.config.mts",
    "src/domains/admin/paymentLinks/hooks/useGetPaymentLinks.ts",
    "src/domains/admin/support/hooks/useTicketListingApi.ts",
    "src/domains/dashboard/Airline/hooks/useSearchAirport.tsx",
    "src/domains/dashboard/GiftCards/hooks/useGetEmployeeApi.ts",
    "src/domains/dashboard/Payroll",
    "src/domains/dashboard/Reports/hooks/useGetReportsApi.ts",
    "src/domains/dashboard/Subscriptions/slice/paymentSlice.ts",
    "src/domains/dashboard/esim",
    "src/domains/dashboard/esimV2",
    "src/domains/dashboard/esr/pages/EsrDocumentSuccess.tsx",
    "src/domains/dashboard/needHelp/hooks/useTicketListingApi.ts"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "src/**/*",
    "tests/**/*",
    "commitlint.config.js",
    "tailwind.config.js",
    "webpack.config.js",
    "postcss.config.js",
    "vitest.setup.ts"
  ],
  "references": []
}